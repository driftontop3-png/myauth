POSTGRES_URL="auto-set-by-vercel-postgres-pooled"
POSTGRES_URL_NON_POOLING="auto-set-by-vercel-postgres-direct"
JWT_SECRET="generate-a-long-random-secret-here"

# Vercel Postgres sets POSTGRES_URL and POSTGRES_URL_NON_POOLING automatically.
# Do NOT swap them. JWT_SECRET must be added manually in Vercel Settings.
